datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Routine {
  id        String   @id @default(cuid())
  userId    String   // Añadido para relacionar con usuario
  weekStart DateTime
  createdAt DateTime @default(now())
  
  days      DailyWorkout[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyWorkout {
  id          String   @id @default(cuid())
  routineId   String
  dayOfWeek   String   
  date        DateTime? 
  type        String   // 'Gym', 'Cycling', 'Rest'
  
  // Cycling targets
  targetDuration Int?    // minutes
  targetPower    String? // e.g. "Zone 2"
  
  // Actuals
  actualDuration Int?
  distance       Float?
  averageHeartRate Int?
  rpe            Int?    // 1-10
  notes          String?
  completed      Boolean @default(false)
  creatineTaken  Boolean @default(false)
  
  routine     Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
}

model Exercise {
  id             String   @id @default(cuid())
  dailyWorkoutId String
  
  name           String
  targetSets     Int
  targetReps     String?  
  
  dailyWorkout   DailyWorkout @relation(fields: [dailyWorkoutId], references: [id], onDelete: Cascade)
  logs           WorkoutLog[]
}

model WorkoutLog {
  id         String   @id @default(cuid())
  exerciseId String
  
  setNumber  Int
  reps       Int
  weight     Float    
  
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// NextAuth models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Strava integration
  stravaAthleteId    String?
  stravaAccessToken  String?
  stravaRefreshToken String?
  stravaTokenExpiry  Int?     // Unix timestamp

  // Google Fit integration
  googleFitAccessToken  String?
  googleFitRefreshToken String?
  googleFitTokenExpiry  Int?    // Unix timestamp (seconds)

  accounts      Account[]
  sessions      Session[]
  routines      Routine[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
